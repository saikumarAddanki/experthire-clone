# Postgres connection string — Supabase's POOLED connection (port 6543, used at runtime)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-x-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Postgres DIRECT connection (port 5432, used only for schema migrations/db push)
# Same project, same password — just port 5432 instead of 6543, no pgbouncer param.
# Find it in Supabase: Project Settings > Database > Connection string > "Direct connection" tab
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-x-xx-xxxx-1.pooler.supabase.com:5432/postgres"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# No GROQ_API_KEY here on purpose — there's no shared/fallback key.
# Each user adds their own free Groq key from inside the app
# (the key icon in the top bar → /settings/keys). Get one at
# https://console.groq.com/keys
